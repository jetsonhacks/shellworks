# shellworks/.env.example
#
# Copy this file to .env and fill in values for your setup.
# .env is excluded from version control. .env.example is committed.
#
# cp .env.example .env

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Active endpoint — must match a filename in configs/endpoints/ (without .toml)
# Available endpoints are in configs/endpoints/
# Examples: local_thor, local_orin
SHELLWORKS_ENDPOINT=local_primary

# API keys — each endpoint's TOML file specifies which env var to read
# via the api_key_env field. Local servers accept any non-empty string.
VLLM_API_KEY=not-needed
LOCAL_LLM_API_KEY=not-needed

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Override the endpoint's default_model for a single run without editing
# the endpoint TOML. Leave unset to use the default_model from the TOML.
# SHELLWORKS_MODEL=nvidia/Qwen3-8B-FP8

# Override the configs directory location.
# Defaults to ./configs relative to the working directory.
# SHELLWORKS_CONFIGS_DIR=/path/to/configs

# ---------------------------------------------------------------------------
# HuggingFace — required by server launcher scripts in scripts/
# ---------------------------------------------------------------------------

# Used by scripts/llama_server.sh and the vLLM Docker launchers to
# download gated models. Not read by shellworks itself.
# HF_TOKEN=hf_...
